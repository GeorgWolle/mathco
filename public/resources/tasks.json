      "task_id": "1_1425",
      "aufgabentyp": "Typ 1",
      "grundkompetenz": "AG 1.1",
      "punkte": "[0 / 1 P.]",
      "bewertung": "Ein Punkt für das richtige Ankreuzen."
    },
    "text": "Gegeben sind die Mengen $A = \\{x \\in \\mathbb{R} \\mid -1 < x < 0\\}$ und $B = \\{y \\in \\mathbb{Q} \\mid -1 < y < 0\\}$.",
    "text_latex": true,
    "interaction": {
      "type": "multi_choice",
      "instruction": "Kreuzen Sie die beiden zutreffenden Aussagen an.",
      "select_count": 2,
      "choices": [
        {
          "key": "1",
          "display": "$A$ und $B$ enthalten jeweils ganze Zahlen.",
          "latex": true
        },
        {
          "key": "2",
          "display": "Die Summe zweier Elemente aus $B$ liegt in jedem Fall in $A$.",
          "latex": true
        },
        {
          "key": "3",
          "display": "Jedes Element von $B$ ist auch Element von $A$.",
          "latex": true
        },
        {
          "key": "4",
          "display": "Das Produkt zweier Elemente aus $B$ liegt in jedem Fall in $A$.",
          "latex": true
        },
        {
          "key": "5",
          "display": "$A$ und $B$ sind jeweils eine Teilmenge der komplexen Zahlen.",
          "latex": true
        }
      ]
    }
  },
  {
    "page": 6,
    "id": 6,
    "type": "solution",
    "task_id": 5,
    "correct_answers": [
      {
        "key": "3",
        "display": "Jedes Element von $B$ ist auch Element von $A$.",
        "latex": true,
        "explanation": "B \\subseteq \\mathbb{Q} \\subseteq \\mathbb{R} \\text{ und beide haben dasselbe Intervall} \\Rightarrow B \\subseteq A"
      },
      {
        "key": "5",
        "display": "$A$ und $B$ sind jeweils eine Teilmenge der komplexen Zahlen.",
        "latex": true,
        "explanation": "\\mathbb{R} \\subset \\mathbb{C} \\text{ und } \\mathbb{Q} \\subset \\mathbb{C} \\Rightarrow A \\subset \\mathbb{C},\\; B \\subset \\mathbb{C}"
      }
    ],
    "lösungsweg": [
      {
        "step": 1,
        "text": "\\text{Aussage 1: Das Intervall } (-1, 0) \\text{ enthält keine ganzen Zahlen} \\Rightarrow \\text{falsch}",
        "latex": true
      },
      {
        "step": 2,
        "text": "\\text{Aussage 2: z.B. } (-0{,}5) + (-0{,}5) = -1 \\notin A \\text{ (offenes Intervall!)} \\Rightarrow \\text{falsch}",
        "latex": true
      },
      {
        "step": 3,
        "text": "\\text{Aussage 3: } B \\subseteq \\mathbb{Q} \\subseteq \\mathbb{R},\\; \\text{gleiches Intervall} \\Rightarrow B \\subseteq A \\checkmark",
        "latex": true
      },
      {
        "step": 4,
        "text": "\\text{Aussage 4: z.B. } (-0{,}5) \\cdot (-0{,}5) = 0{,}25 \\notin A \\text{ (nur negative Werte in } A\\text{)} \\Rightarrow \\text{falsch}",
        "latex": true
      },
      {
        "step": 5,
        "text": "\\text{Aussage 5: } \\mathbb{R} \\subset \\mathbb{C} \\text{ und } \\mathbb{Q} \\subset \\mathbb{C} \\Rightarrow A \\subset \\mathbb{C},\\; B \\subset \\mathbb{C} \\checkmark",
        "latex": true
      }
    ],
    "bewertung": {
      "max_punkte": 1,
      "teilpunkte": [
        { "punkte": 1, "bedingung": "Beide Aussagen richtig angekreuzt" },
        { "punkte": 0, "bedingung": "Weniger als zwei richtige Antworten" }
      ]
    }
  }
