      "bewertung": "Ein Punkt für das richtige Ankreuzen."
    },
    "text": "Für die von null verschiedenen ganzen Zahlen $a$ und $b$ gilt: $a = -4 \\cdot b$",
    "text_latex": true,
    "interaction": {
      "type": "multi_choice",
      "instruction": "Kreuzen Sie die beiden Terme an, die in jedem Fall eine natürliche Zahl ergeben.",
      "select_count": 2,
      "choices": [
        { "key": "1", "display": "a - b",           "latex": true },
        { "key": "2", "display": "\\frac{-a}{b}",   "latex": true },
        { "key": "3", "display": "a + b",            "latex": true },
        { "key": "4", "display": "(-a - b)^{2}",    "latex": true },
        { "key": "5", "display": "a \\cdot b",       "latex": true }
      ]
    }
  },
  {
    "page": 4,
    "id": 4,
    "type": "solution",
    "task_id": 3,
    "correct_answers": [
      {
        "key": "2",
        "display": "\\frac{-a}{b}",
        "latex": true,
        "explanation": "\\frac{-a}{b} = \\frac{-(-4b)}{b} = \\frac{4b}{b} = 4 \\in \\mathbb{N}"
      },
      {
        "key": "4",
        "display": "(-a - b)^{2}",
        "latex": true,
        "explanation": "(-a - b)^{2} = (4b - b)^{2} = (3b)^{2} = 9b^{2} \\in \\mathbb{N}"
      }
    ],
    "lösungsweg": [
      {
        "step": 1,
        "text": "a = -4b \\text{ einsetzen und jeden Term prüfen:}",
        "latex": true
      },
      {
        "step": 2,
        "text": "a - b = -4b - b = -5b \\quad \\Rightarrow \\text{ kann negativ sein} \\Rightarrow \\notin \\mathbb{N}",
        "latex": true
      },
      {
        "step": 3,
        "text": "\\frac{-a}{b} = \\frac{4b}{b} = 4 \\in \\mathbb{N} \\checkmark",
        "latex": true
      },
      {
        "step": 4,
        "text": "a + b = -4b + b = -3b \\quad \\Rightarrow \\text{ kann negativ sein} \\Rightarrow \\notin \\mathbb{N}",
        "latex": true
      },
      {
        "step": 5,
        "text": "(-a - b)^{2} = (3b)^{2} = 9b^{2} > 0 \\in \\mathbb{N} \\checkmark",
        "latex": true
      },
      {
        "step": 6,
        "text": "a \\cdot b = -4b \\cdot b = -4b^{2} < 0 \\quad \\Rightarrow \\notin \\mathbb{N}",
        "latex": true
      }
    ],
    "bewertung": {
      "max_punkte": 1,
      "teilpunkte": [
        { "punkte": 1, "bedingung": "Beide Terme richtig angekreuzt" },
        { "punkte": 0, "bedingung": "Weniger als zwei richtige Antworten" }
      ]
    }
  },
  {
    "page": 5,
    "id": 5,
    "type": "task",
    "meta": {
      "title": "Zahlenmengen",
